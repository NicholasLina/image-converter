<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:CompileBindings="False"
        d:DesignWidth="1100"
        d:DesignHeight="720"
        x:Class="ImageConverter.Gui.MainWindow"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        Title="Image Converter"
        KeyDown="MainWindow_OnKeyDown">
    <Grid Margin="16"
          ColumnDefinitions="*,320"
          RowDefinitions="Auto,Auto,*,Auto"
          ColumnSpacing="16"
          RowSpacing="12">
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Name="DropZone"
                Background="#10235A89"
                BorderBrush="#905AA9E6"
                BorderThickness="2"
                CornerRadius="10"
                Padding="16"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="DropZone_OnDragOver"
                DragDrop.Drop="DropZone_OnDrop"
                AutomationProperties.Name="Drop zone"
                AutomationProperties.HelpText="Drop image files or folders to add them to the conversion queue.">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="Drop images or folders here to start converting"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Or use Add images / Add folder. Supported inputs include PNG, JPEG, WebP, AVIF, TIFF, BMP, GIF, ICO, HDR, PNM, DDS, TGA, QOI, and EXR."
                           MaxWidth="920"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="8">
            <Button Name="AddFilesButton"
                    Content="Add images..."
                    Click="AddFilesButton_OnClick"
                    TabIndex="0"
                    AutomationProperties.Name="Add image files"
                    AutomationProperties.HelpText="Open a file picker to add one or more image files. Shortcut: Ctrl+O." />
            <Button Name="AddFolderButton"
                    Content="Add folder..."
                    Click="AddFolderButton_OnClick"
                    TabIndex="1"
                    AutomationProperties.Name="Add image folder"
                    AutomationProperties.HelpText="Open a folder picker to import supported images recursively. Shortcut: Ctrl+Shift+O." />
            <Button Name="RemoveSelectedButton"
                    Content="Remove selected"
                    Click="RemoveSelectedButton_OnClick"
                    TabIndex="2"
                    AutomationProperties.Name="Remove selected rows"
                    AutomationProperties.HelpText="Remove selected conversion jobs from the queue. Shortcut: Delete." />
            <Button Name="ClearButton"
                    Content="Clear list"
                    Click="ClearButton_OnClick"
                    TabIndex="3"
                    AutomationProperties.Name="Clear queue"
                    AutomationProperties.HelpText="Remove all queued jobs." />
            <Button Name="EstimateButton"
                    Content="Estimate sizes"
                    Click="EstimateButton_OnClick"
                    TabIndex="4"
                    AutomationProperties.Name="Estimate output sizes"
                    AutomationProperties.HelpText="Refresh output size estimates for queued jobs." />
        </StackPanel>

        <DataGrid Grid.Row="2"
                  Grid.Column="0"
                  Name="JobsGrid"
                  Margin="0,4,0,4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  CanUserSortColumns="False"
                  CanUserReorderColumns="False"
                  TabIndex="5"
                  AutomationProperties.Name="Conversion queue"
                  AutomationProperties.HelpText="List of queued files with source size, estimated output size, and status.">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*" />
                <DataGridTextColumn Header="Input Path" Binding="{Binding InputPath}" Width="4*" />
                <DataGridTextColumn Header="Source Size" Binding="{Binding SourceSize}" Width="130" />
                <DataGridTextColumn Header="Estimated Size" Binding="{Binding EstimatedSize}" Width="140" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Grid.Column="0" ColumnDefinitions="*,240" ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="3">
                <TextBlock Name="SummaryText" Text="No images yet. Add files or drop a folder to begin." />
                <TextBlock Name="EstimateSummaryText" Text="Estimated output: --" Foreground="#D0D0D0" />
            </StackPanel>

            <ProgressBar Grid.Column="1"
                         Name="ConversionProgressBar"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="1"
                Grid.RowSpan="3"
                Grid.Column="1"
                Background="#0DFFFFFF"
                BorderBrush="#35FFFFFF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="Output format" FontWeight="SemiBold" />
                <ComboBox Grid.Row="1"
                          Name="FormatComboBox"
                          Margin="0,6,0,12"
                          SelectionChanged="FormatComboBox_OnSelectionChanged"
                          TabIndex="6"
                          AutomationProperties.Name="Output format"
                          AutomationProperties.HelpText="Select the destination image format for conversion.">
                    <ComboBoxItem Content="JPEG (.jpg)" Tag="Jpeg" />
                    <ComboBoxItem Content="PNG (.png)" Tag="Png" />
                    <ComboBoxItem Content="WebP (.webp)" Tag="WebP" />
                    <ComboBoxItem Content="AVIF (.avif)" Tag="Avif" />
                    <ComboBoxItem Content="TIFF (.tiff)" Tag="Tiff" />
                    <ComboBoxItem Content="BMP (.bmp)" Tag="Bmp" />
                    <ComboBoxItem Content="GIF (.gif)" Tag="Gif" />
                </ComboBox>

                <TextBlock Grid.Row="2" Text="Quality" FontWeight="SemiBold" />
                <Grid Grid.Row="3" Margin="0,6,0,12" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Slider Grid.Column="0"
                            Name="QualitySlider"
                            Minimum="1"
                            Maximum="100"
                            TickFrequency="1"
                            ValueChanged="QualitySlider_OnValueChanged"
                            IsSnapToTickEnabled="True"
                            TabIndex="7"
                            AutomationProperties.Name="Quality slider"
                            AutomationProperties.HelpText="Adjust JPEG and AVIF quality from 1 to 100." />
                    <TextBlock Grid.Column="1" Name="QualityLabel" Text="85" VerticalAlignment="Center" />
                </Grid>
                <TextBlock Grid.Row="4"
                           Name="QualityHelpText"
                           Text="(used for JPEG/AVIF)"
                           Margin="0,0,0,12"
                           Foreground="#AAFFFFFF" />

                <TextBlock Grid.Row="5" Text="Output folder" FontWeight="SemiBold" />
                <StackPanel Grid.Row="6" Margin="0,6,0,0" Spacing="8">
                    <TextBox Name="OutputFolderTextBox"
                             IsReadOnly="True"
                             Watermark="Choose destination folder"
                             TextWrapping="WrapWithOverflow"
                             AcceptsReturn="True"
                             MinHeight="58"
                             TabIndex="8"
                             AutomationProperties.Name="Output folder path"
                             AutomationProperties.HelpText="Current destination folder for converted files." />
                    <Button Name="BrowseOutputButton"
                            Content="Choose folder..."
                            Click="BrowseOutputButton_OnClick"
                            TabIndex="9"
                            AutomationProperties.Name="Choose output folder"
                            AutomationProperties.HelpText="Open a folder picker to choose where converted files are saved." />
                </StackPanel>

                <Button Grid.Row="7"
                        Name="ConvertButton"
                        Content="Convert files"
                        Click="ConvertButton_OnClick"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Margin="0,16,0,0"
                        Classes="accent"
                        TabIndex="10"
                        AutomationProperties.Name="Convert queued images"
                        AutomationProperties.HelpText="Start conversion for all queued images. Shortcut: Ctrl+Enter." />
            </Grid>
        </Border>
    </Grid>
</Window>
